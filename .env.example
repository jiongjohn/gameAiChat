# Storage backend: "json" (default, zero-config) or "postgres"
AI_CHAT_STORE=json

# JSON backend: where the state file lives (optional)
# AI_CHAT_STATE_PATH=.data/companion-state.json

# Postgres backend (required when AI_CHAT_STORE=postgres)
# Matches docker-compose.yml credentials:
# DATABASE_URL=postgres://aichat:aichat@localhost:5432/aichat

# Admin console + admin APIs (/admin, /api/admin/*) HTTP Basic auth.
# Required in production; if unset the admin surface returns 503.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-in-production

# Session signing secret for H5 user login (register/login/logout).
# Required for user auth; falls back to ADMIN_PASSWORD if unset.
SESSION_SECRET=change-me-session-secret
# Seed demo account (auto-created): username "demo", password "companion123" — change in production.
